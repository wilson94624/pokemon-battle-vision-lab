  "cv_recognition_rules": {
    "species_identification_evidence_priority": [
      "team-side candidate roster",
      "species icon match",
      "type-combination match",
      "display-name OCR as supporting evidence only",
      "previous/next battle-state consistency"
    ],
    "nickname_rule": "Displayed names may be custom nicknames and must not be treated as canonical species identity.",
    "type_inference_rule": "Type combinations may narrow candidates, but cannot always uniquely identify a species.",
    "turn_selection_rule": "During move selection, detect which player status panel is highlighted to identify whether the left or right active Pokémon is being operated.",
    "move_menu_rule": {
      "record": [
        "controlled player slot",
        "four move names if not already supplied by team data",
        "displayed move type icons",
        "displayed effectiveness hints"
      ],
      "ignore": [
        "PP",
        "gender",
        "cursor position",
        "assumed final selected move",
        "assumed target"
      ]
    },
    "battle_text_rule": {
      "source_of_truth": true,
      "required_fields": [
        "actor",
        "action_or_move",
        "target_or_targets_when inferable",
        "result",
        "raw_text",
        "timestamp"
      ],
      "event_pattern": "who -> used/did what -> affected whom -> result"
    }
  },
  "labels": {
    "screen_states": [
      "TEAM_PREVIEW",
      "PLAYER_FOUR_CONFIRMED",
      "MOVE_SELECTION_PLAYER_LEFT",
      "MOVE_SELECTION_PLAYER_RIGHT",
      "BATTLE_TEXT",
      "RESULT",
      "UNKNOWN"
    ],
    "effectiveness_hints": [
      "super_effective",
      "effective",
      "not_very_effective",
      "no_effect",
      "not_shown"
    ]
  }
