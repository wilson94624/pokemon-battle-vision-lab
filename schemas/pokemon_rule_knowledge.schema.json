{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/pokemon_rule_knowledge.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "knowledge_version", "kind", "ruleset_scope", "language", "sources", "moves", "species_types", "type_effectiveness", "ability_rules", "explicit_rules", "target_rules", "scope_guards"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "knowledge_version": {"type": "string", "minLength": 1},
    "kind": {"const": "pokemon_rule_knowledge"},
    "ruleset_scope": {"const": "minimal_gen9_reference_for_checkpoint1i"},
    "language": {"const": "zh-Hant"},
    "sources": {"type": "array", "minItems": 4, "items": {"$ref": "#/$defs/source"}},
    "moves": {"type": "array", "minItems": 3, "items": {"$ref": "#/$defs/move"}},
    "species_types": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/speciesType"}},
    "type_effectiveness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "rule_id", "rule_version", "default_multiplier", "entries", "source_refs"],
      "properties": {
        "knowledge_id": {"const": "type-chart:minimal-gen9"},
        "rule_id": {"const": "type_effectiveness.multiply_target_types.v1"},
        "rule_version": {"const": "1.0.0"},
        "default_multiplier": {"const": 1.0},
        "entries": {"type": "array", "minItems": 5, "items": {"$ref": "#/$defs/typeEntry"}},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "ability_rules": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/abilityRule"}},
    "explicit_rules": {"type": "array", "minItems": 2, "items": {"$ref": "#/$defs/explicitRule"}},
    "target_rules": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/targetRule"}},
    "scope_guards": {
      "type": "object",
      "additionalProperties": false,
      "required": ["complete_simulator", "damage_calculator", "legality_engine", "decision_engine", "battle_facts_created", "battle_facts_modified"],
      "properties": {
        "complete_simulator": {"const": false},
        "damage_calculator": {"const": false},
        "legality_engine": {"const": false},
        "decision_engine": {"const": false},
        "battle_facts_created": {"const": false},
        "battle_facts_modified": {"const": false}
      }
    }
  },
  "$defs": {
    "sourceRefs": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "decision", "url", "revision", "license", "input_sha256", "usage"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "decision": {"enum": ["adopted", "adapted", "referenced", "rejected"]},
        "url": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "license": {"type": "string", "minLength": 1},
        "input_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
        "usage": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "move": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "move_id", "aliases", "move_type", "category", "target", "source_refs"],
      "properties": {
        "knowledge_id": {"type": "string", "pattern": "^move:"},
        "move_id": {"type": "string", "minLength": 1},
        "aliases": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
        "move_type": {"type": "string", "minLength": 1},
        "category": {"enum": ["Physical", "Special", "Status"]},
        "target": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "speciesType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "canonical_species_id", "canonical_name", "types", "source_refs"],
      "properties": {
        "knowledge_id": {"type": "string", "pattern": "^species-type:"},
        "canonical_species_id": {"type": "integer", "minimum": 1},
        "canonical_name": {"type": "string", "minLength": 1},
        "types": {"type": "array", "minItems": 1, "maxItems": 2, "uniqueItems": true, "items": {"type": "string"}},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "typeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attacking_type", "defending_type", "multiplier"],
      "properties": {
        "attacking_type": {"type": "string"},
        "defending_type": {"type": "string"},
        "multiplier": {"enum": [0.0, 0.5, 1.0, 2.0]}
      }
    },
    "abilityRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "ability_id", "aliases", "rule_id", "rule_version", "applies_to_move_types", "applies_to_categories", "requires_other_pokemon_source", "accepted_failure_results", "source_refs"],
      "properties": {
        "knowledge_id": {"type": "string", "pattern": "^ability-rule:"},
        "ability_id": {"type": "string", "minLength": 1},
        "aliases": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}},
        "rule_id": {"type": "string", "minLength": 1},
        "rule_version": {"const": "1.0.0"},
        "applies_to_move_types": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "applies_to_categories": {"type": "array", "uniqueItems": true, "items": {"enum": ["Physical", "Special", "Status"]}},
        "requires_other_pokemon_source": {"type": "boolean"},
        "accepted_failure_results": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "explicitRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "rule_id", "rule_version", "fact_type", "required_metadata", "conclusion_code", "source_refs"],
      "properties": {
        "knowledge_id": {"type": "string", "pattern": "^explicit-rule:"},
        "rule_id": {"type": "string", "minLength": 1},
        "rule_version": {"const": "1.0.0"},
        "fact_type": {"const": "MOVE_RESOLVED"},
        "required_metadata": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string"}},
        "conclusion_code": {"type": "string", "minLength": 1},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    },
    "targetRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["knowledge_id", "rule_id", "rule_version", "move_id", "expected_target", "explicit_success_results", "source_refs"],
      "properties": {
        "knowledge_id": {"type": "string", "pattern": "^target-rule:"},
        "rule_id": {"type": "string", "minLength": 1},
        "rule_version": {"const": "1.0.0"},
        "move_id": {"type": "string"},
        "expected_target": {"type": "string"},
        "explicit_success_results": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "source_refs": {"$ref": "#/$defs/sourceRefs"}
      }
    }
  }
}
