{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/checkpoint1f_review_summary.schema.json",
  "title": "Checkpoint 1F Human Review Summary",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "status", "reviewed_by", "reviewed_at", "summary", "special_notes"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1F"},
    "kind": {"const": "checkpoint1f_human_review_summary"},
    "status": {"const": "complete"},
    "reviewed_by": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "minLength": 1},
    "summary": {"type": "string", "minLength": 1},
    "special_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timeline_id", "note"],
        "properties": {
          "timeline_id": {"type": "string"},
          "note": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
