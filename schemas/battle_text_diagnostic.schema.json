{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/battle_text_diagnostic.schema.json",
  "title": "Checkpoint 1B BATTLE_TEXT Sample Diagnostic",
  "type": "object",
  "required": [
    "sample_index",
    "timestamp",
    "pts",
    "frame_ordinal",
    "battle_text_score",
    "threshold",
    "raw_positive",
    "strong_positive",
    "weak_positive",
    "evidence_level",
    "candidate_active_before",
    "candidate_active_after",
    "candidate_id",
    "closed_candidate_id",
    "decision",
    "suppression_reason",
    "boundary_reason",
    "open_reason",
    "close_reason",
    "merge_reason",
    "split_reason",
    "layout_change_score",
    "layout_reference_distance",
    "weak_run_length",
    "negative_run_length",
    "template_similarity",
    "template_strength",
    "visual_structure_strength",
    "positive_reasons",
    "negative_reasons",
    "layout_fingerprint",
    "features"
  ],
  "properties": {
    "sample_index": {"type": "integer", "minimum": 0},
    "timestamp": {"type": "string"},
    "pts": {"type": "number", "minimum": 0},
    "frame_ordinal": {"type": "integer", "minimum": 0},
    "battle_text_score": {"type": "number", "minimum": 0, "maximum": 1},
    "threshold": {"type": "number", "minimum": 0, "maximum": 1},
    "raw_positive": {"type": "boolean"},
    "strong_positive": {"type": "boolean"},
    "weak_positive": {"type": "boolean"},
    "evidence_level": {"enum": ["strong", "weak", "negative"]},
    "candidate_active_before": {"type": "boolean"},
    "candidate_active_after": {"type": "boolean"},
    "candidate_id": {"type": "string"},
    "closed_candidate_id": {"type": "string"},
    "decision": {
      "enum": [
        "open_candidate",
        "continue_candidate",
        "close_candidate",
        "negative",
        "bridged_gap",
        "bridged_same_layout_reopen",
        "continue_weak",
        "split_on_visual_change",
        "split_on_layout_transition"
      ]
    },
    "suppression_reason": {"type": "string"},
    "boundary_reason": {"type": "string"},
    "open_reason": {"type": "string"},
    "close_reason": {"type": "string"},
    "merge_reason": {"type": "string"},
    "split_reason": {"type": "string"},
    "layout_change_score": {"type": "number", "minimum": 0, "maximum": 1},
    "layout_reference_distance": {"type": "number", "minimum": 0, "maximum": 1},
    "weak_run_length": {"type": "integer", "minimum": 0},
    "negative_run_length": {"type": "integer", "minimum": 0},
    "template_similarity": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "template_strength": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "visual_structure_strength": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
    "positive_reasons": {"type": "array", "items": {"type": "string"}},
    "negative_reasons": {"type": "array", "items": {"type": "string"}},
    "layout_fingerprint": {"type": "object"},
    "features": {"type": "object"}
  },
  "additionalProperties": false
}
