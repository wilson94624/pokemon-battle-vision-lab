{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/pokemon_knowledge_base.schema.json",
  "title": "Versioned Pokémon Knowledge Base",
  "type": "object",
  "required": [
    "schema_version",
    "knowledge_base_version",
    "kind",
    "language",
    "current_regulation",
    "sources",
    "counts",
    "species",
    "forms",
    "aliases",
    "regulation_entries",
    "sprite_metadata"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "knowledge_base_version": {"type": "string", "minLength": 1},
    "kind": {"const": "pokemon_knowledge_base"},
    "language": {"const": "zh-Hant"},
    "current_regulation": {
      "type": "object",
      "required": ["regulation_id", "display_name", "effective_from", "effective_until", "official_url", "roster_url", "availability_semantics"]
    },
    "sources": {
      "type": "array",
      "minItems": 4,
      "items": {"$ref": "#/$defs/source"}
    },
    "counts": {
      "type": "object",
      "required": ["species", "forms", "pokeapi_forms", "champions_mega_forms", "aliases", "regulation_entries", "sprite_metadata"],
      "additionalProperties": {"type": "integer", "minimum": 0}
    },
    "species": {
      "type": "array",
      "minItems": 1025,
      "maxItems": 1025,
      "items": {"$ref": "#/$defs/species"}
    },
    "forms": {
      "type": "array",
      "minItems": 1579,
      "items": {"$ref": "#/$defs/form"}
    },
    "aliases": {
      "type": "array",
      "minItems": 1025,
      "items": {"$ref": "#/$defs/alias"}
    },
    "regulation_entries": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/regulationEntry"}
    },
    "sprite_metadata": {
      "type": "array",
      "minItems": 1351,
      "maxItems": 1351,
      "items": {"$ref": "#/$defs/spriteMetadata"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["source_id", "status", "url", "revision", "license", "usage", "input_sha256"],
      "properties": {
        "source_id": {"type": "string", "minLength": 1},
        "status": {"type": "string", "minLength": 1},
        "url": {"type": "string", "minLength": 1},
        "revision": {"type": "string", "minLength": 1},
        "license": {"type": "string", "minLength": 1},
        "usage": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "input_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}
      },
      "additionalProperties": false
    },
    "regulationAvailability": {
      "type": "object",
      "required": ["regulation_id", "status"],
      "properties": {
        "regulation_id": {"const": "pokemon-champions-m-b"},
        "status": {"enum": ["eligible", "not_eligible", "unknown_form_crosswalk"]},
        "eligible_champions_codes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "basis": {"type": "string"}
      },
      "additionalProperties": false
    },
    "species": {
      "type": "object",
      "required": ["canonical_species_id", "canonical_identifier", "generation_id", "english_name", "traditional_chinese_name", "default_pokemon_id", "regulation_availability"],
      "properties": {
        "canonical_species_id": {"type": "integer", "minimum": 1},
        "canonical_identifier": {"type": "string", "minLength": 1},
        "generation_id": {"type": "integer", "minimum": 1},
        "english_name": {"type": "string", "minLength": 1},
        "traditional_chinese_name": {"type": "string", "minLength": 1},
        "default_pokemon_id": {"type": ["integer", "null"], "minimum": 1},
        "regulation_availability": {"$ref": "#/$defs/regulationAvailability"}
      },
      "additionalProperties": false
    },
    "form": {
      "type": "object",
      "required": ["form_key", "source_id", "canonical_species_id", "pokemon_id", "form_id", "pokemon_identifier", "form_identifier", "english_form_name", "traditional_chinese_form_name", "is_default", "is_battle_only", "is_mega", "form_order", "regulation_availability"],
      "properties": {
        "form_key": {"type": "string", "minLength": 1},
        "source_id": {"type": "string", "minLength": 1},
        "canonical_species_id": {"type": "integer", "minimum": 1},
        "pokemon_id": {"type": ["integer", "null"], "minimum": 1},
        "form_id": {"type": ["integer", "null"], "minimum": 1},
        "pokemon_identifier": {"type": ["string", "null"]},
        "form_identifier": {"type": ["string", "null"]},
        "english_form_name": {"type": ["string", "null"]},
        "traditional_chinese_form_name": {"type": ["string", "null"]},
        "is_default": {"type": "boolean"},
        "is_battle_only": {"type": "boolean"},
        "is_mega": {"type": "boolean"},
        "form_order": {"type": "integer", "minimum": 0},
        "regulation_availability": {"$ref": "#/$defs/regulationAvailability"}
      },
      "additionalProperties": false
    },
    "alias": {
      "type": "object",
      "required": ["normalized_alias", "aliases", "canonical_species_ids", "source_ids"],
      "properties": {
        "normalized_alias": {"type": "string", "minLength": 1},
        "aliases": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "canonical_species_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1}},
        "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "regulationEntry": {
      "type": "object",
      "required": ["regulation_id", "champions_code", "canonical_species_id", "champions_form_code", "official_english_name", "pokeapi_pokemon_id", "mapping_status", "availability", "source_id"],
      "properties": {
        "regulation_id": {"const": "pokemon-champions-m-b"},
        "champions_code": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{3}$"},
        "canonical_species_id": {"type": "integer", "minimum": 1},
        "champions_form_code": {"type": "string", "pattern": "^[0-9]{3}$"},
        "official_english_name": {"type": "string", "minLength": 1},
        "pokeapi_pokemon_id": {"type": ["integer", "null"], "minimum": 1},
        "mapping_status": {"enum": ["default_form_exact", "form_identifier_keywords_exact", "species_only"]},
        "availability": {"const": "eligible"},
        "source_id": {"const": "pokemon-champions.regulation-m-b"}
      },
      "additionalProperties": false
    },
    "assetDomain": {
      "type": "object",
      "required": ["visual_domain", "available", "repository_path", "pinned_raw_url"],
      "properties": {
        "visual_domain": {"type": "string", "minLength": 1},
        "available": {"type": "boolean"},
        "repository_path": {"type": ["string", "null"]},
        "pinned_raw_url": {"type": ["string", "null"]},
        "reason": {"type": "string"}
      },
      "additionalProperties": false
    },
    "spriteMetadata": {
      "type": "object",
      "required": ["pokemon_id", "canonical_species_id", "pokemon_identifier", "source_revision", "domains"],
      "properties": {
        "pokemon_id": {"type": "integer", "minimum": 1},
        "canonical_species_id": {"type": "integer", "minimum": 1},
        "pokemon_identifier": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "domains": {
          "type": "object",
          "required": ["battle_sprite_default", "home_artwork", "official_artwork", "showdown_animation", "generation_viii_icon", "pokemon_champions_icon"],
          "additionalProperties": {"$ref": "#/$defs/assetDomain"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
