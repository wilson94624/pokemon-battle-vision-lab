{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/checkpoint1f_manifest.schema.json",
  "title": "Checkpoint 1F Manifest",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "status", "projector_version", "source", "snapshot_count", "projected_group_count", "delta_count", "conflict_count", "unresolved_update_count", "outputs", "content_digests", "validation", "scope_guards"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1F"},
    "kind": {"const": "checkpoint1f_manifest"},
    "status": {"const": "complete"},
    "projector_version": {"type": "string"},
    "source": {"type": "object"},
    "snapshot_count": {"type": "integer", "minimum": 1},
    "projected_group_count": {"type": "integer", "minimum": 0},
    "delta_count": {"type": "integer", "minimum": 0},
    "conflict_count": {"type": "integer", "minimum": 0},
    "unresolved_update_count": {"type": "integer", "minimum": 0},
    "outputs": {"type": "object", "additionalProperties": {"$ref": "#/$defs/file"}},
    "content_digests": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "validation": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "scope_guards": {"type": "object", "additionalProperties": {"type": "boolean"}}
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
