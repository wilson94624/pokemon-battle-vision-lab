    "total_review_record_count": {"type": "integer", "minimum": 1}, "accepted_count": {"type": "integer", "minimum": 0}, "rejected_count": {"type": "integer", "minimum": 0}, "needs_review_count": {"type": "integer", "minimum": 0}, "deferred_count": {"type": "integer", "minimum": 0},
    "supported_interpretation_count": {"type": "integer", "minimum": 0}, "unresolved_interpretation_count": {"type": "integer", "minimum": 0}, "conflicted_interpretation_count": {"type": "integer", "minimum": 0}, "human_review_complete": {"type": "boolean"}
