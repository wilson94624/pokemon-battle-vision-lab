{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/state_review_records.schema.json",
  "title": "Checkpoint 1F Human Review Records",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "record_count", "records"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1F"},
    "kind": {"const": "state_review_records"},
    "record_count": {"type": "integer", "minimum": 0},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["review_id", "timeline_id", "snapshot_before", "snapshot_after", "source_event_ids", "events", "delta_id", "delta_status", "operation_count", "unresolved_count", "conflict_count", "confidence", "before_completeness", "after_completeness", "review_status", "review_reasons", "review_card_path", "human_review"],
        "properties": {
          "review_id": {"type": "string", "pattern": "^state-review-[0-9]{4}$"},
          "timeline_id": {"type": "string"},
          "snapshot_before": {"type": "string"},
          "snapshot_after": {"type": "string"},
          "source_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
          "events": {"type": "array", "minItems": 1, "items": {"type": "object"}},
          "delta_id": {"type": "string"},
          "delta_status": {"enum": ["applied", "no_op", "unresolved", "partial", "conflicted"]},
          "operation_count": {"type": "integer", "minimum": 0},
          "unresolved_count": {"type": "integer", "minimum": 0},
          "conflict_count": {"type": "integer", "minimum": 0},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "before_completeness": {"type": "number", "minimum": 0, "maximum": 1},
          "after_completeness": {"type": "number", "minimum": 0, "maximum": 1},
          "review_status": {"enum": ["auto_accepted", "needs_review"]},
          "review_reasons": {"type": "array", "items": {"type": "string"}},
          "review_card_path": {"type": "string"},
          "human_review": {
            "type": "object",
            "required": ["human_decision", "human_action", "human_entity", "human_field", "human_value", "reviewed_by", "reviewed_at", "review_note"],
            "additionalProperties": {"type": ["string", "null"]}
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
