{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/state_conflicts.schema.json",
  "title": "Checkpoint 1F State Conflicts",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "conflict_count", "conflicts"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1F"},
    "kind": {"const": "state_conflicts"},
    "conflict_count": {"type": "integer", "minimum": 0},
    "conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["conflict_id", "timeline_id", "event_id", "conflict_type", "entity", "field", "existing", "proposed", "evidence", "confidence", "review_status", "human_review"],
        "properties": {
          "conflict_id": {"type": "string", "pattern": "^conflict-[0-9]{4}$"},
          "timeline_id": {"type": "string"},
          "event_id": {"type": "string"},
          "conflict_type": {"type": "string"},
          "entity": {"type": "string"},
          "field": {"type": "string"},
          "existing": {},
          "proposed": {},
          "evidence": {"type": "object"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "review_status": {"const": "needs_review"},
          "human_review": {"type": "object"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
