{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/ocr_frame_selection.schema.json",
  "title": "Checkpoint 1C OCR Frame Selections",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "candidate_count", "selection_count", "records"],
  "properties": {
    "schema_version": {"type": "string"},
    "checkpoint": {"const": "1C"},
    "kind": {"const": "ocr_frame_selections"},
    "candidate_count": {"type": "integer", "minimum": 0},
    "selection_count": {"type": "integer", "minimum": 0},
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event_id", "event_type", "frame_ordinal", "pts", "selection_reason", "selection_reasons", "roi_name", "image_path", "frame_quality", "visual_text_strength", "detector_template_strength", "insufficient_frame_reason"],
        "properties": {
          "event_id": {"type": "string"},
          "event_type": {"enum": ["BATTLE_TEXT", "TRIGGER_NOTIFICATION"]},
          "frame_ordinal": {"type": "integer", "minimum": 0},
          "pts": {"type": "number", "minimum": 0},
          "selection_reason": {"type": "string"},
          "selection_reasons": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "roi_name": {"type": "string"},
          "image_path": {"type": "string"},
          "frame_quality": {"type": "number", "minimum": 0, "maximum": 1},
          "visual_text_strength": {"type": "number", "minimum": 0, "maximum": 1},
          "detector_template_strength": {"type": "number", "minimum": 0, "maximum": 1},
          "insufficient_frame_reason": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
