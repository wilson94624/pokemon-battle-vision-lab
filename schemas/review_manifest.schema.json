{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/review_manifest.schema.json",
  "title": "Checkpoint 1B Human Review Pack Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "checkpoint",
    "status",
    "generated_at",
    "generator",
    "source_candidates_preserved",
    "detector_rerun",
    "ocr_performed",
    "checkpoint_1c_started",
    "candidate_count",
    "candidate_counts_by_type",
    "source_hashes_before",
    "source_hashes_after",
    "immutable_sources_unchanged",
    "frame_extraction",
    "candidate_review",
    "contact_sheets",
    "coverage_review",
    "dense_recall_audit",
    "battle_text_round1_regression",
    "trigger_notification_round1_regression",
    "battle_text_recall_summary",
    "validation"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "checkpoint": {"const": "1B_HUMAN_REVIEW"},
    "status": {"const": "complete_pending_human_review"},
    "generated_at": {"type": "string", "format": "date-time"},
    "generator": {"const": "pokemon_battle_vision.review_pack"},
    "source_candidates_preserved": {"const": true},
    "detector_rerun": {"const": false},
    "ocr_performed": {"const": false},
    "checkpoint_1c_started": {"const": false},
    "candidate_count": {"type": "integer", "minimum": 0},
    "candidate_counts_by_type": {"type": "object"},
    "source_hashes_before": {"type": "object"},
    "source_hashes_after": {"type": "object"},
    "immutable_sources_unchanged": {"const": true},
    "frame_extraction": {"type": "object"},
    "candidate_review": {"type": "object"},
    "contact_sheets": {"type": "object"},
    "coverage_review": {"type": "object"},
    "dense_recall_audit": {"type": "object"},
    "battle_text_round1_regression": {"type": "object"},
    "trigger_notification_round1_regression": {"type": "object"},
    "battle_text_recall_summary": {"type": "object"},
    "validation": {"type": "object"}
  },
  "additionalProperties": false
}
