{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/checkpoint1e_manifest.schema.json",
  "title": "Checkpoint 1E Manifest",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "status", "builder_version", "source", "source_event_count", "timeline_count", "relation_count", "group_status_counts", "relation_status_counts", "unlinked_event_count", "outputs", "validation", "scope_guards"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1E"},
    "kind": {"const": "checkpoint1e_manifest"},
    "status": {"const": "complete"},
    "builder_version": {"type": "string"},
    "source": {"type": "object"},
    "source_event_count": {"type": "integer", "minimum": 0},
    "timeline_count": {"type": "integer", "minimum": 0},
    "relation_count": {"type": "integer", "minimum": 0},
    "group_status_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "relation_status_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "unlinked_event_count": {"type": "integer", "minimum": 0},
    "outputs": {"type": "object", "additionalProperties": {"$ref": "#/$defs/file"}},
    "validation": {"type": "object", "additionalProperties": {"type": "boolean"}},
    "scope_guards": {"type": "object", "additionalProperties": {"type": "boolean"}}
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
