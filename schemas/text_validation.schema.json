{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/text_validation.schema.json",
  "title": "Checkpoint 1C Text Validation Results",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "record_count", "validation_counts", "workflow_counts", "records"],
  "properties": {
    "schema_version": {"type": "string"},
    "checkpoint": {"const": "1C"},
    "kind": {"const": "text_validation_results"},
    "record_count": {"type": "integer", "minimum": 0},
    "validation_counts": {"$ref": "#/$defs/counts"},
    "workflow_counts": {"type": "object", "required": ["auto_accepted", "needs_review", "rejected"], "properties": {"auto_accepted": {"type": "integer", "minimum": 0}, "needs_review": {"type": "integer", "minimum": 0}, "rejected": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "records": {"type": "array", "items": {"$ref": "#/$defs/validation"}}
  },
  "$defs": {
    "counts": {"type": "object", "required": ["VALID_TEXT", "NO_TEXT", "UNCERTAIN"], "properties": {"VALID_TEXT": {"type": "integer", "minimum": 0}, "NO_TEXT": {"type": "integer", "minimum": 0}, "UNCERTAIN": {"type": "integer", "minimum": 0}}, "additionalProperties": false},
    "validation": {
      "type": "object",
      "required": ["event_id", "event_type", "start_time", "end_time", "validation_label", "workflow_status", "ocr_text", "ocr_confidence", "consensus_confidence", "validation_confidence", "review_reasons", "supporting_result_ids", "duplicate_group_id", "possible_duplicate_of", "duplicate_confidence", "human_text", "human_decision", "human_action", "merge_with_event_id", "split_points", "reviewed_at", "reviewed_by"],
      "properties": {
        "event_id": {"type": "string"}, "event_type": {"enum": ["BATTLE_TEXT", "TRIGGER_NOTIFICATION"]},
        "start_time": {"type": "number", "minimum": 0}, "end_time": {"type": "number", "minimum": 0},
        "validation_label": {"enum": ["VALID_TEXT", "NO_TEXT", "UNCERTAIN"]},
        "workflow_status": {"enum": ["auto_accepted", "needs_review", "rejected"]},
        "ocr_text": {"type": "string"}, "ocr_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "consensus_confidence": {"type": "number", "minimum": 0, "maximum": 1}, "validation_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "review_reasons": {"type": "array", "items": {"type": "string"}}, "supporting_result_ids": {"type": "array", "items": {"type": "string"}},
        "duplicate_group_id": {"type": ["string", "null"]}, "possible_duplicate_of": {"type": ["string", "null"]}, "duplicate_confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "human_text": {"type": ["string", "null"]}, "human_decision": {"type": ["string", "null"]},
        "human_action": {"type": ["string", "null"], "enum": [null, "accept", "edit_text", "mark_no_text", "merge_previous", "merge_next", "split"]},
        "merge_with_event_id": {"type": ["string", "null"]}, "split_points": {"type": ["array", "null"], "items": {"type": "number"}},
        "reviewed_at": {"type": ["string", "null"]}, "reviewed_by": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
