{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pokemon-battle-vision.local/schemas/state_deltas.schema.json",
  "title": "Checkpoint 1F State Deltas",
  "type": "object",
  "required": ["schema_version", "checkpoint", "kind", "delta_count", "deltas"],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "checkpoint": {"const": "1F"},
    "kind": {"const": "state_deltas"},
    "delta_count": {"type": "integer", "minimum": 0},
    "deltas": {"type": "array", "items": {"$ref": "#/$defs/delta"}}
  },
  "$defs": {
    "humanReview": {
      "type": "object",
      "required": ["human_decision", "human_action", "human_entity", "human_field", "human_value", "reviewed_by", "reviewed_at", "review_note"],
      "additionalProperties": {"type": ["string", "null"]}
    },
    "operation": {
      "type": "object",
      "required": ["operation", "entity", "field", "before", "after", "confidence", "rule_id", "source_event_ids", "source_relation_ids", "evidence"],
      "properties": {
        "operation": {"type": "string"},
        "entity": {"type": "string"},
        "field": {"type": "string"},
        "before": {},
        "after": {},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "rule_id": {"type": "string"},
        "source_event_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "source_relation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "evidence": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "unresolved": {
      "type": "object",
      "required": ["unresolved_id", "timeline_id", "event_id", "event_type", "reason", "missing_fields", "evidence", "confidence", "human_review"],
      "properties": {
        "unresolved_id": {"type": "string", "pattern": "^unresolved-[0-9]{4}$"},
        "timeline_id": {"type": "string"},
        "event_id": {"type": "string"},
        "event_type": {"type": "string"},
        "reason": {"type": "string"},
        "missing_fields": {"type": "array", "items": {"type": "string"}},
        "evidence": {"type": "object"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "human_review": {"$ref": "#/$defs/humanReview"}
      },
      "additionalProperties": false
    },
    "delta": {
      "type": "object",
      "required": ["delta_id", "sequence", "snapshot_before", "snapshot_after", "timeline_id", "timestamp", "source_group_start_time", "source_group_end_time", "source_event_ids", "operations", "unresolved_updates", "conflict_ids", "projection_rule_ids", "status", "confidence", "no_op_reasons", "review_status", "review_reasons", "human_review", "excluded_rejected_relation_ids"],
      "properties": {
        "delta_id": {"type": "string", "pattern": "^delta-[0-9]{4}$"},
        "sequence": {"type": "integer", "minimum": 1},
        "snapshot_before": {"type": "string"},
        "snapshot_after": {"type": "string"},
        "timeline_id": {"type": "string"},
        "timestamp": {"type": "number", "minimum": 0},
        "source_group_start_time": {"type": "number", "minimum": 0},
        "source_group_end_time": {"type": "number", "minimum": 0},
        "source_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "operations": {"type": "array", "items": {"$ref": "#/$defs/operation"}},
        "unresolved_updates": {"type": "array", "items": {"$ref": "#/$defs/unresolved"}},
        "conflict_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "projection_rule_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "status": {"enum": ["applied", "no_op", "unresolved", "partial", "conflicted"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "no_op_reasons": {"type": "array", "items": {"type": "string"}},
        "review_status": {"enum": ["auto_accepted", "needs_review"]},
        "review_reasons": {"type": "array", "items": {"type": "string"}},
        "human_review": {"$ref": "#/$defs/humanReview"},
        "excluded_rejected_relation_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
